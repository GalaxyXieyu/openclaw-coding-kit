{
  "scenario_id": "prod-admin-admin-dashboard-settings-audit-logs",
  "engine": "web-playwright-cli",
  "entry_node_id": "admin-login",
  "target_node_id": "admin-dashboard-settings-audit-logs",
  "target": {
    "base_url": "https://eggturtles-admin.sealoshzh.site",
    "auth_surface": "admin",
    "auth_profile": "eggturtle-prod-admin-siri",
    "browser_channel": "chrome",
    "viewport_size": "1440,1000",
    "full_page": true
  },
  "context": {
    "notes": "默认复用持久化登录态直接打开目标页。"
  },
  "steps": [
    {
      "action": "open",
      "target": "/dashboard/settings/audit-logs"
    },
    {
      "action": "wait",
      "ms": 1200
    }
  ],
  "assertions": [
    {
      "type": "selector",
      "selector": "#audit-tenant"
    },
    {
      "type": "selector",
      "selector": "#audit-user"
    }
  ],
  "capture": {
    "mode": "screenshot",
    "output": "../screenshots/prod-admin-admin-dashboard-settings-audit-logs.png"
  }
}